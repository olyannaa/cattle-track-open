    { "required": ["animal_id"] }
  ],
  "examples": [
    {
      "schema_version": "v1",
      "tag": "1432"
    },
    {
      "schema_version": "v1",
      "animal_id": "be7d9e62-9163-43fa-98e5-6ce7a2665317"
    }
  ],
  "x-invalid-examples": [
    {
      "schema_version": "v1",
      "animal_id": "1432"
    }
