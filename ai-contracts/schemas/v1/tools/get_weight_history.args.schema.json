{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cattle-track.local/ai-contracts/schemas/v1/tools/get_weight_history.args.schema.json",
  "title": "get_weight_history arguments",
  "x-tool-name": "get_weight_history",
  "x-tool-version": "v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version"],
  "properties": {
    "schema_version": { "$ref": "../common/defs.schema.json#/$defs/schema_version" },
    "tag": { "$ref": "../common/defs.schema.json#/$defs/tag" },
    "animal_id": { "$ref": "../common/defs.schema.json#/$defs/uuid" },
    "date_from": { "$ref": "../common/defs.schema.json#/$defs/date" },
    "date_to": { "$ref": "../common/defs.schema.json#/$defs/date" },
    "limit": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100,
      "default": 20
    }
  },
  "anyOf": [
    { "required": ["tag"] },
    { "required": ["animal_id"] }
  ],
  "examples": [
    {
      "schema_version": "v1",
      "tag": "1432",
      "limit": 10
    },
    {
      "schema_version": "v1",
      "animal_id": "be7d9e62-9163-43fa-98e5-6ce7a2665317",
      "limit": 10
    }
  ],
  "x-invalid-examples": [
    {
      "schema_version": "v1",
      "animal_id": "be7d9e62-9163-43fa-98e5-6ce7a2665317",
      "limit": 1000
    }
  ]
}
