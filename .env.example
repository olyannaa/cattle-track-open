POSTGRES_CONNECTION_STRING=Host=<host>;Port=5432;Database=<db>;Username=<user>;Password=<password>
TELEGRAM_BOT_API_KEY=<telegram-bot-token>
FRONTEND_PUBLIC_URL=http://localhost:3000
VITE_API_URL=http://localhost:5001/api/

# Optional local ports and ids.
BACKEND_PORT=5001
FRONTEND_PORT=3000
REDIS_PORT=6379
REDIS_INSTANCE_NAME=LinksCachinglocal
LOCAL_ADMIN_ROLE_ID=00000000-0000-0000-0000-000000000000
ORG_ADMIN_ROLE_ID=00000000-0000-0000-0000-000000000000

# Optional local demo PostgreSQL used by docker-compose.demo.yml.
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cattletrack_demo
POSTGRES_PORT=5433

# Optional AI runtime wiring for docker-compose.demo.yml.
AI_LLM_PROVIDER=disabled
AI_LLM_ENDPOINT=
AI_LLM_MODEL=
AI_LLM_OUTPUT_MODE=constrained-json
AI_ASR_PROVIDER=disabled
AI_ASR_ENDPOINT=
AI_ASR_MODEL=
